---
import { Font } from 'astro:assets';
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Dojo — Japanese Grammar Drills', description = 'Interactive practice platform for Japanese grammar.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    {/* Dark mode initialization — runs BEFORE page renders to avoid flash */}
    <script is:inline>
      const saved = localStorage.getItem('theme');
      const isDark = saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches);
      if (isDark) document.documentElement.classList.add('dark');
    </script>

    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-noto-sans-jp" preload />
  </head>
  <body class="bg-white dark:bg-slate-950">
    <slot />
  </body>
</html>
