---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Dojo — Japanese Grammar Drills', description = 'Interactive practice platform for Japanese grammar.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
