---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<BaseLayout title={title}>
  <div class="min-h-screen flex flex-col">
    <Header current="drills" />

    {/* Main content */}
    <main class="flex-1">
      <div class="max-w-2xl mx-auto px-4 py-6 sm:px-6 sm:py-8">
        <slot />
      </div>
    </main>

    {/* Footer */}
    <footer class="border-t border-border mt-12">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-6 text-center">
        <p class="text-sm text-muted">Dojo — Japanese Grammar Drills</p>
      </div>
    </footer>
  </div>
</BaseLayout>
