---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  score?: number;
  total?: number;
}

const { title, score = 0, total = 0 } = Astro.props;
---

<BaseLayout title={title}>
  <div class="flex flex-col min-h-screen">
    {/* Header with progress */}
    <header class="bg-slate-100 dark:bg-slate-900 border-b border-slate-200 dark:border-slate-700 sticky top-0 z-10">
      <div class="max-w-4xl mx-auto pl-4 pr-4 pt-4 pb-4 flex items-center justify-between">
        <div class="flex items-center gap-4">
          <a href="/" class="text-sm text-slate-900 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-400 transition">
            ← Back
          </a>
          <h1 class="text-xl font-semibold text-slate-900 dark:text-white">{title}</h1>
        </div>

        {/* Progress indicator */}
        {total > 0 && (
          <div class="flex items-center gap-3">
            <span class="text-sm text-slate-500 dark:text-slate-400">{score} / {total}</span>
            <div class="w-32 h-2 bg-slate-200 dark:bg-slate-700 rounded-full overflow-hidden">
              <div
                class="h-full bg-indigo-600 dark:bg-indigo-500 transition-all duration-300"
                style={`width: ${(score / total) * 100}%`}
              />
            </div>
          </div>
        )}
      </div>
    </header>

    {/* Main content */}
    <main class="flex-1">
      <div class="max-w-2xl mx-auto pl-4 pr-4 pt-8 pb-8">
        <slot />
      </div>
    </main>

    {/* Footer */}
    <footer class="border-t border-slate-200 dark:border-slate-700 bg-slate-100 dark:bg-slate-900 mt-12">
      <div class="max-w-4xl mx-auto pl-4 pr-4 pt-6 pb-6 text-center text-sm text-slate-500 dark:text-slate-400">
        <p>Dojo — Japanese Grammar Drills</p>
      </div>
    </footer>
  </div>
</BaseLayout>
