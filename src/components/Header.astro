---
interface Props {
  current?: string;
}

const { current = 'home' } = Astro.props;
---

<nav class="sticky top-0 z-50 bg-bg/85 backdrop-blur-lg border-b border-border">
  <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
    <a href="/" class="font-display text-xl font-bold text-fg flex items-center gap-2 no-underline">
      <img src="/favicon.svg" alt="Dojo" class="w-7 h-7" />
      Dojo
    </a>
    <ul class="flex gap-1 list-none m-0 p-0">
      <li><a href="/" class:list={['text-sm font-medium no-underline px-4 py-1.5 rounded-full transition-colors duration-150', current === 'home' ? 'text-fg bg-surface-2' : 'text-muted hover:text-fg-secondary hover:bg-border']}>Home</a></li>
      <li><a href="/drills" class:list={['text-sm font-medium no-underline px-4 py-1.5 rounded-full transition-colors duration-150', current === 'drills' ? 'text-fg bg-surface-2' : 'text-muted hover:text-fg-secondary hover:bg-border']}>Drills</a></li>
    </ul>
  </div>
</nav>
