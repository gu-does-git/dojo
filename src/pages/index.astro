---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
---

<BaseLayout title="Dojo — Japanese Grammar Drills" description="Master Japanese grammar through interactive drills.">
  <Header title="Dojo" />

  <div class="min-h-screen bg-light-bg dark:bg-dark-bg">
    {/* Hero section */}
    <section class="max-w-4xl mx-auto px-4 py-20 text-center">
      <h1 class="text-5xl font-inter font-bold mb-4 text-light-text dark:text-dark-text">
        Dojo
      </h1>
      <p class="text-xl text-light-muted dark:text-dark-muted mb-8">
        Master Japanese grammar through interactive drills
      </p>
      <a
        href="/drills"
        class="inline-block px-6 py-3 bg-accent dark:bg-accent-dark text-white rounded-lg font-semibold hover:opacity-90 transition"
      >
        Start Learning
      </a>
    </section>

    {/* Drill categories grid */}
    <section class="max-w-4xl mx-auto px-4 py-12">
      <h2 class="text-3xl font-inter font-bold mb-8 text-light-text dark:text-dark-text">
        Grammar Drills
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {/* Past Form */}
        <a
          href="/drills/past-form"
          class="p-6 rounded-lg bg-light-surface dark:bg-dark-surface border border-light-border dark:border-dark-border hover:border-accent dark:hover:border-accent-dark transition cursor-pointer"
        >
          <h3 class="text-xl font-semibold text-light-text dark:text-dark-text mb-2">
            過去形 (Past Form)
          </h3>
          <p class="text-light-muted dark:text-dark-muted mb-4">
            Master past tense conjugation for N5 verbs
          </p>
          <div class="inline-block px-3 py-1 bg-accent dark:bg-accent-dark text-white text-sm rounded">
            N5
          </div>
        </a>

        {/* Particles */}
        <a
          href="/drills/particles"
          class="p-6 rounded-lg bg-light-surface dark:bg-dark-surface border border-light-border dark:border-dark-border hover:border-accent dark:hover:border-accent-dark transition cursor-pointer"
        >
          <h3 class="text-xl font-semibold text-light-text dark:text-dark-text mb-2">
            助詞 (Particles)
          </h3>
          <p class="text-light-muted dark:text-dark-muted mb-4">
            Learn は, が, を, に particle usage
          </p>
          <div class="inline-block px-3 py-1 bg-accent2 dark:bg-accent2-dark text-white text-sm rounded">
            N5
          </div>
        </a>
      </div>
    </section>

    {/* Footer */}
    <footer class="border-t border-light-border dark:border-dark-border mt-20">
      <div class="max-w-4xl mx-auto px-4 py-8 text-center text-sm text-light-muted dark:text-dark-muted">
        <p>Dojo v0.1.0 — Interactive Japanese Grammar Learning</p>
      </div>
    </footer>
  </div>

  <style is:global>
    .bg-light-bg {
      background: var(--bg-light);
    }
    html.dark .bg-light-bg {
      background: var(--bg-dark);
    }

    .text-light-text {
      color: var(--text-light);
    }
    html.dark .text-light-text {
      color: var(--text-dark);
    }

    .text-light-muted {
      color: var(--muted-light);
    }
    html.dark .text-light-muted {
      color: var(--muted-dark);
    }

    .bg-light-surface {
      background: var(--surface-light);
    }
    html.dark .bg-light-surface {
      background: var(--surface-dark);
    }

    .border-light-border {
      border-color: var(--border-light);
    }
    html.dark .border-light-border {
      border-color: var(--border-dark);
    }

    .bg-accent {
      background: var(--accent);
    }
    html.dark .bg-accent {
      background: var(--accent-dark);
    }

    .bg-accent2 {
      background: var(--accent2);
    }
    html.dark .bg-accent2 {
      background: var(--accent2-dark);
    }

    .hover\:border-accent:hover {
      border-color: var(--accent);
    }
    html.dark .dark\:hover\:border-accent-dark:hover {
      border-color: var(--accent-dark);
    }
  </style>
</BaseLayout>
