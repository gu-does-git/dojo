---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
---

<BaseLayout title="Dojo — Japanese Grammar Drills" description="Master Japanese grammar through interactive drills.">
  <Header title="Dojo" />

  <main class="min-h-screen bg-gradient-to-br from-white via-slate-50 to-blue-50 dark:from-slate-950 dark:via-slate-900 dark:to-slate-800">
    {/* Hero section */}
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32">
      <div class="text-center">
        <h1 class="text-6xl sm:text-7xl font-bold tracking-tight mb-6">
          <span class="bg-gradient-to-r from-indigo-600 via-blue-500 to-purple-600 dark:from-indigo-400 dark:via-blue-400 dark:to-purple-400 bg-clip-text text-transparent">
            Dojo
          </span>
        </h1>
        <p class="text-xl sm:text-2xl text-slate-600 dark:text-slate-300 mb-4 font-light">
          Master Japanese grammar through interactive drills
        </p>
        <p class="text-lg text-slate-500 dark:text-slate-400 mb-10 max-w-2xl mx-auto">
          Practice past tense, particles, and more with instant feedback
        </p>
        <a
          href="/drills"
          class="inline-flex items-center gap-2 px-8 py-4 bg-indigo-600 dark:bg-indigo-500 text-white rounded-full font-semibold hover:bg-indigo-700 dark:hover:bg-indigo-600 transition-all shadow-lg hover:shadow-xl hover:scale-105"
        >
          Start Learning
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
      </div>
    </section>

    {/* Drill categories grid */}
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="text-center mb-16">
        <h2 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-white mb-4">
          Grammar Drills
        </h2>
        <p class="text-lg text-slate-600 dark:text-slate-400">
          Choose a drill to start practicing
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {/* Past Form */}
        <a
          href="/drills/past-form"
          class="group relative overflow-hidden rounded-2xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:border-indigo-500 dark:hover:border-indigo-400 transition-all hover:shadow-2xl hover:-translate-y-1"
        >
          <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"/>
          <div class="relative p-8 sm:p-10">
            <div class="mb-6 inline-block p-3 rounded-lg bg-indigo-100 dark:bg-indigo-900/30">
              <span class="text-2xl font-bold text-indigo-600 dark:text-indigo-400">過</span>
            </div>
            <h3 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white mb-3">
              Past Form
            </h3>
            <p class="text-slate-600 dark:text-slate-400 mb-6 leading-relaxed">
              Master past tense conjugation for N5 verbs. Learn group 1, 2, and irregular conjugations with instant feedback.
            </p>
            <div class="flex items-center justify-between">
              <span class="inline-block px-4 py-2 bg-indigo-600 dark:bg-indigo-500 text-white text-sm font-semibold rounded-full">
                N5
              </span>
              <span class="text-indigo-600 dark:text-indigo-400 font-semibold group-hover:translate-x-1 transition-transform">
                →
              </span>
            </div>
          </div>
        </a>

        {/* Particles */}
        <a
          href="/drills/particles"
          class="group relative overflow-hidden rounded-2xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:border-purple-500 dark:hover:border-purple-400 transition-all hover:shadow-2xl hover:-translate-y-1"
        >
          <div class="absolute inset-0 bg-gradient-to-br from-purple-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"/>
          <div class="relative p-8 sm:p-10">
            <div class="mb-6 inline-block p-3 rounded-lg bg-purple-100 dark:bg-purple-900/30">
              <span class="text-2xl font-bold text-purple-600 dark:text-purple-400">助</span>
            </div>
            <h3 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white mb-3">
              Particles
            </h3>
            <p class="text-slate-600 dark:text-slate-400 mb-6 leading-relaxed">
              Learn は, が, を, に particle usage in context. Understand when and how to use each particle correctly.
            </p>
            <div class="flex items-center justify-between">
              <span class="inline-block px-4 py-2 bg-purple-600 dark:bg-purple-500 text-white text-sm font-semibold rounded-full">
                N5
              </span>
              <span class="text-purple-600 dark:text-purple-400 font-semibold group-hover:translate-x-1 transition-transform">
                →
              </span>
            </div>
          </div>
        </a>
      </div>
    </section>

    {/* Stats section */}
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="text-4xl font-bold text-indigo-600 dark:text-indigo-400 mb-2">2</div>
          <p class="text-slate-600 dark:text-slate-400">Drills Available</p>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-blue-600 dark:text-blue-400 mb-2">N5</div>
          <p class="text-slate-600 dark:text-slate-400">Starting Level</p>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-purple-600 dark:text-purple-400 mb-2">∞</div>
          <p class="text-slate-600 dark:text-slate-400">Practice Sessions</p>
        </div>
      </div>
    </section>

    {/* Footer */}
    <footer class="border-t border-slate-200 dark:border-slate-700 mt-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 text-center">
        <p class="text-sm text-slate-600 dark:text-slate-400">
          Dojo v0.1.0 — Interactive Japanese Grammar Learning
        </p>
      </div>
    </footer>
  </main>
</BaseLayout>
