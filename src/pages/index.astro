---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

const drills = await getCollection('drills');

// Dynamic stats
const grammarCount = drills.filter(d => d.data.type === 'conjugation').reduce((sum, d) => sum + d.data.questions.length, 0);
const particleCount = drills.filter(d => d.data.type === 'particles').reduce((sum, d) => sum + d.data.questions.length, 0);
const totalQuestions = drills.reduce((sum, d) => sum + d.data.questions.length, 0);

// Group by type for categories
const categories = [
  { type: 'conjugation', icon: '文', label: 'Grammar Points', color: 'accent', desc: 'Verb conjugations, sentence patterns, and essential structures.' },
  { type: 'particles', icon: '助', label: 'Particles', color: 'gold', desc: 'は、が、を、に、で、と、の、も、へ、and combinations.' },
];

function getLevels(drills: any[], type: string) {
  const levels = [...new Set(drills.filter(d => d.data.type === type).map(d => d.data.level))];
  return levels.sort().join(' – ');
}

function getCount(drills: any[], type: string) {
  return drills.filter(d => d.data.type === type).reduce((sum, d) => sum + d.data.questions.length, 0);
}
---

<BaseLayout title="Dojo — Japanese Grammar Drills">
  <Header current="home" />

  <main>
    {/* Hero */}
    <section class="max-w-5xl mx-auto px-6 pt-12 sm:pt-20 pb-12 text-center">
      <span class="inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider text-accent bg-accent-soft px-3 py-1 rounded-full mb-5">
        🏔️ JLPT N5 → N3
      </span>
      <h1 class="font-display text-3xl sm:text-6xl font-bold tracking-tight leading-none mb-4">
        Master Japanese<br><em class="not-italic text-accent">Grammar</em> & Particles
      </h1>
      <p class="text-base sm:text-lg text-fg-secondary max-w-lg mx-auto mb-4 sm:mb-9 leading-relaxed">
        Interactive drills with instant feedback. Type your answer, learn from mistakes, build real understanding.
      </p>
      <div class="flex gap-3 justify-center flex-wrap">
        <a href="/drills" class="inline-flex items-center gap-1.5 px-6 py-3 bg-accent text-white rounded-lg text-base font-semibold hover:brightness-112 hover:-translate-y-px transition-all">
          Start Drilling →
        </a>
      </div>
    </section>

    {/* Stats */}
    <section class="max-w-5xl mx-auto px-6 pb-12 border-b border-border">
      <div class="grid grid-cols-2 gap-3">
        <div class="text-center py-5">
          <div class="text-3xl font-bold text-accent tabular-nums">{totalQuestions}</div>
          <div class="text-sm text-muted mt-0.5">Total Questions</div>
        </div>
        <div class="text-center py-5">
          <div class="text-3xl font-bold text-gold tabular-nums">{drills.length}</div>
          <div class="text-sm text-muted mt-0.5">Drill Sets</div>
        </div>
      </div>
    </section>

    {/* Categories — dynamic from content collection */}
    <section class="max-w-5xl mx-auto px-6 py-12">
      <h2 class="font-display text-xl font-bold mb-5">Categories</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {categories.map((cat) => {
          const count = getCount(drills, cat.type);
          const levels = getLevels(drills, cat.type);
          const colorClass = cat.color === 'gold' ? 'bg-gold-soft text-gold' : 'bg-accent-soft text-accent';
          const borderHover = cat.color === 'gold' ? 'hover:border-gold/40' : 'hover:border-accent-mid';

          return (
            <a
              href={`/drills?filter=${cat.type}`}
              class={`block bg-surface border border-border rounded-lg p-6 ${borderHover} hover:shadow-2xl hover:-translate-y-0.5 transition-all no-underline text-fg`}
            >
              <div class={`w-11 h-11 rounded-[10px] ${colorClass} flex items-center justify-center text-2xl mb-4`}>
                {cat.icon}
              </div>
              <h3 class="text-base font-semibold mb-1">{cat.label}</h3>
              <p class="text-sm text-muted leading-snug">{cat.desc}</p>
              <div class="flex gap-3 mt-3.5 text-xs text-muted">
                <span>{count} questions</span>
                {levels && <span>{levels}</span>}
              </div>
            </a>
          );
        })}
      </div>
    </section>

    {/* Footer */}
    <footer class="border-t border-border mt-12">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10 text-center">
        <p class="text-sm text-muted">Dojo — Interactive Japanese Grammar Learning</p>
      </div>
    </footer>
  </main>
</BaseLayout>
