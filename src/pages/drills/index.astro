---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const drills = await getCollection('drills');
---

<BaseLayout title="Drills — Dojo" description="All available Japanese grammar drills.">
  <Header current="drills" />

  <main>
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-10 pb-20">
      {/* Page Header */}
      <div class="mb-6">
        <h1 class="font-display text-3xl font-bold tracking-tight mb-1.5">All Drills</h1>
        <p class="text-sm text-muted">Choose a drill set and start practicing.</p>
      </div>

      {/* Filter Bar */}
      <div class="flex items-center gap-1.5 sm:gap-2 mb-6 flex-wrap">
        <button class="filter-pill text-xs px-2.5 sm:px-3.5 py-1 sm:py-1.5 rounded-full border border-border-strong bg-transparent text-fg-secondary cursor-pointer font-medium transition-all hover:border-muted hover:text-fg" data-filter="all">All</button>
        <button class="filter-pill text-xs px-2.5 sm:px-3.5 py-1 sm:py-1.5 rounded-full border border-border-strong bg-transparent text-fg-secondary cursor-pointer font-medium transition-all hover:border-muted hover:text-fg" data-filter="conjugation">Grammar</button>
        <button class="filter-pill text-xs px-2.5 sm:px-3.5 py-1 sm:py-1.5 rounded-full border border-border-strong bg-transparent text-fg-secondary cursor-pointer font-medium transition-all hover:border-muted hover:text-fg" data-filter="particles">Particles</button>
        <button class="filter-pill text-xs px-2.5 sm:px-3.5 py-1 sm:py-1.5 rounded-full border border-border-strong bg-transparent text-fg-secondary cursor-pointer font-medium transition-all hover:border-muted hover:text-fg" data-filter="n5">N5</button>
        <button class="filter-pill text-xs px-2.5 sm:px-3.5 py-1 sm:py-1.5 rounded-full border border-border-strong bg-transparent text-fg-secondary cursor-pointer font-medium transition-all hover:border-muted hover:text-fg" data-filter="n4">N4</button>
        <button class="filter-pill text-xs px-2.5 sm:px-3.5 py-1 sm:py-1.5 rounded-full border border-border-strong bg-transparent text-fg-secondary cursor-pointer font-medium transition-all hover:border-muted hover:text-fg" data-filter="n3">N3</button>
        <input
          type="text"
          id="searchInput"
          placeholder="Search drills…"
          class="px-3.5 mt-2 sm:mt-0 sm:ml-auto sm:px-3.5 py-1.5 rounded-full border border-border-strong bg-surface text-fg text-sm outline-none w-full sm:min-w-45 focus:border-accent transition-colors placeholder:text-muted"
        />
      </div>

      {/* Drill List */}
      <div id="drillList" class="flex flex-col gap-1.5">
        {drills.map((drill) => {
          const isConjugation = drill.data.type === 'conjugation';

          return (
            <a
              href={`/drills/${drill.id}`}
              class="drill-row flex items-center gap-4 px-4 py-3 sm:px-5 sm:py-4 bg-surface border border-border rounded-lg hover:border-accent-mid hover:bg-surface-2 transition-all no-underline text-fg group"
              data-category={drill.data.type}
              data-level={drill.data.level.toLowerCase()}
              data-title={drill.data.title.toLowerCase()}
              data-desc={drill.data.description?.toLowerCase() ?? ''}
            >
              <div class="flex-1 min-w-0">
                <div class="text-base font-semibold flex items-center gap-2 flex-wrap mb-0.5">
                  {drill.data.title}
                  <span class={`text-xs font-bold px-1.5 py-0.5 rounded-full uppercase tracking-wide ${
                    drill.data.level === 'N5' ? 'bg-success/15 text-success' :
                    drill.data.level === 'N4' ? 'bg-accent-soft text-accent' :
                    'bg-gold-soft text-gold'
                  }`}>
                    {drill.data.level}
                  </span>
                  <span class={`text-xs font-semibold uppercase tracking-wider px-2 py-0.5 rounded-full ${
                    isConjugation ? 'bg-accent-soft text-accent' : 'bg-gold-soft text-gold'
                  }`}>
                    {isConjugation ? 'Grammar' : 'Particles'}
                  </span>
                </div>
                <p class="text-sm text-muted truncate">{drill.data.description}</p>
              </div>
              <div class="hidden md:flex items-center gap-2 text-sm text-muted">
                <span>{drill.data.questions.length} questions</span>
              </div>
              <span class="hidden md:inline text-base text-muted transition-colors drill-row-arrow">→</span>
            </a>
          );
        })}
      </div>

      {/* Empty state */}
      <div id="emptyState" class="hidden text-center py-16 text-muted">
        <div class="text-4xl mb-3">🔍</div>
        <h3 class="text-base text-fg-secondary mb-1">No drills found</h3>
        <p class="text-sm">Try a different filter or search term.</p>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>

<script>
  const pills = document.querySelectorAll('.filter-pill');
  const rows = document.querySelectorAll('.drill-row');
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const emptyState = document.getElementById('emptyState')!;
  const drillList = document.getElementById('drillList')!;
  let currentFilter = 'all';

  function activatePill(target: Element) {
    pills.forEach(p => {
      p.classList.remove('bg-accent', 'text-white', 'border-accent');
      p.classList.add('bg-transparent', 'text-fg-secondary', 'border-border-strong');
    });
    target.classList.remove('bg-transparent', 'text-fg-secondary', 'border-border-strong');
    target.classList.add('bg-accent', 'text-white', 'border-accent');
  }

  // Set initial active on "All"
  activatePill(pills[0]);

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      activatePill(pill);
      currentFilter = pill.dataset.filter!;
      filter();
    });
  });

  searchInput?.addEventListener('input', filter);

  function filter() {
    const search = (searchInput?.value ?? '').toLowerCase();
    let visible = 0;

    rows.forEach(row => {
      const el = row as HTMLElement;
      const cat = el.dataset.category ?? '';
      const level = el.dataset.level ?? '';
      const title = el.dataset.title ?? '';
      const desc = el.dataset.desc ?? '';

      const matchFilter = currentFilter === 'all' || cat === currentFilter || level === currentFilter;
      const matchSearch = !search || title.includes(search) || desc.includes(search);

      if (matchFilter && matchSearch) {
        el.style.display = '';
        visible++;
      } else {
        el.style.display = 'none';
      }
    });

    drillList.style.display = visible > 0 ? '' : 'none';
    emptyState.style.display = visible > 0 ? 'none' : '';
  }

  // Auto-activate filter from URL query param
  const urlFilter = new URLSearchParams(window.location.search).get('filter');
  if (urlFilter) {
    const targetPill = document.querySelector(`.filter-pill[data-filter="${urlFilter}"]`) as HTMLElement;
    if (targetPill) {
      activatePill(targetPill);
      currentFilter = urlFilter;
      filter();
    }
  }
</script>
