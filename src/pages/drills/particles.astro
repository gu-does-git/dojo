---
import { getCollection } from 'astro:content';
import DrillLayout from '../../layouts/DrillLayout.astro';

const drills = await getCollection('drills');
const drill = drills.find(d => d.id === 'particles');

if (!drill) {
  return new Response('Drill not found', { status: 404 });
}
---

<DrillLayout title={drill.data.title}>
  <div class="space-y-8">
    <div class="prose dark:prose-invert max-w-none">
      <p class="text-lg text-slate-600 dark:text-slate-300">{drill.data.description}</p>
    </div>

    <div class="space-y-6">
      {drill.data.questions.map((q, idx) => (
        <div class="p-6 bg-slate-50 dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700">
          <div class="mb-4">
            <span class="text-sm font-semibold text-slate-500 dark:text-slate-400">Question {idx + 1} of {drill.data.questions.length}</span>
          </div>
          <div class="mb-6">
            <p class="text-2xl font-bold text-slate-900 dark:text-white mb-2">{q.prompt}</p>
            <p class="text-base text-slate-600 dark:text-slate-300 font-light italic">{q.romaji}</p>
          </div>
          <div class="space-y-3">
            <div class="p-4 bg-white dark:bg-slate-700 rounded border border-slate-300 dark:border-slate-600">
              <p class="text-sm text-slate-500 dark:text-slate-400 mb-1">Correct particle:</p>
              <p class="text-3xl font-semibold text-purple-600 dark:text-purple-400">{q.answer}</p>
            </div>
            {q.hint && (
              <div class="p-3 bg-purple-50 dark:bg-purple-900/20 rounded border border-purple-200 dark:border-purple-800">
                <p class="text-sm text-purple-700 dark:text-purple-300"><strong>Explanation:</strong> {q.hint}</p>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</DrillLayout>
